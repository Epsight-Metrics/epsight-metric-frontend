# Environment Variables untuk Frontend

# Backend API URL (REQUIRED for production)
VITE_API_URL=https://your-backend-url.railway.app

# CV Stream URL (REQUIRED for production)
VITE_CV_STREAM_URL=https://your-cv-program-url.railway.app/video_feed

# Local Development
# VITE_API_URL=http://localhost:3000
# VITE_CV_STREAM_URL=http://localhost:5000/video_feed
